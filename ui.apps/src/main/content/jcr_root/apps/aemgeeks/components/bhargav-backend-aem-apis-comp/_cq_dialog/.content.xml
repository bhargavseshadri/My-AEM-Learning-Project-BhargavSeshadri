<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="nt:unstructured"
          jcr:title="Weather Component"
          sling:resourceType="cq/gui/components/authoring/dialog">
    <content
            granite:class="cmp-author_editor"
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/tabs"
                    maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <basic
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Basic"
                            sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">

                            <personname
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldLabel="Person Name"
                                    name="./personName"/>

                            <fathername
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldLabel="Father Name"
                                    name="./fatherName"/>

                            <averageincome
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                    fieldDescription="Provide the Average Income of this Family"
                                    fieldLabel="Average Income"
                                    name="./averageIncome"/>

                            <multifield jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                        fieldLable="Multifield">
                                <field jcr:primaryType="nt:unstructured"
                                       sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                       name="./multifieldvalues">

                                </field>

                            </multifield>

                        </items>
                    </basic>
                    <multifieldwithbean
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Multifield With Bean"
                            sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <well
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/well"
                                    fieldLabel="Product Quantity Details">
                                <items jcr:primaryType="nt:unstructured">
                                    <productdetailsbean
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                            composite="{Boolean}true"
                                            fieldDescription="Product Details"
                                            fieldLabel="Product Details"
                                            required="{Boolean}false">
                                        <field
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/container"
                                                emptyText="Product Details"
                                                name="./productdetails">
                                            <items jcr:primaryType="nt:unstructured">
                                                <productname
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                        emptyText="Product Name"
                                                        fieldLabel="Product Name"
                                                        name="./productnamemultifield"/>

                                                <buyerName
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                        emptyText="Buyer Name"
                                                        fieldLabel="Buyer Name"
                                                        name="./buyerName"/>

                                                <quantity
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                                        fieldLabel="Quantity"
                                                        name="./quantity"/>
                                            </items>
                                        </field>
                                    </productdetailsbean>
                                </items>
                            </well>
                        </items>
                    </multifieldwithbean>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
